#!/bin/sh -eu

xdg_state_home=${XDG_STATE_HOME:-$HOME/.local/state}
crypt_file=${CRYPT_FILE:-$xdg_state_home/crypt}

touch "$crypt_file"
chmod 600 "$crypt_file"

trap 'bw lock; unset BW_SESSION' EXIT
BW_SESSION=$(bw unlock --raw)
export BW_SESSION

bw sync
{
  echo "export IRC_LIBERA_PASSWORD=\"$(bw get password irc.libera.chat:6697)\""
  echo "export MAIL_ARCHLINUX_PASSWORD=\"$(bw get password mail.archlinux.org)\""
  echo "export OPENAI_API_KEY=\"$(bw get notes OPENAI_API_KEY)\""
} | gpg --encrypt --recipient 888285CF6ED6758F > "$crypt_file"
