#!/bin/sh -eu

xdg_state_home=${XDG_STATE_HOME:-$HOME/.local/state}
crypt_file=${CRYPT_FILE:-$xdg_state_home/crypt}

tmpfile=$(mktemp)

trap "bw lock; unset BW_SESSION; rm -f $tmpfile" EXIT
BW_SESSION=$(bw unlock --raw)
export BW_SESSION

bw sync
bw get attachment 888285CF6ED6758F.subkeys.priv.asc \
  --itemid 5da1e4ec-bf54-4e80-a4c1-b0d300e8d6b4 \
  --output "$tmpfile"
gpg --import "$tmpfile"
