[core]
  eol = lf
  pager = less -x1,5
[user]
  email = carl.smedstad@protonmail.com
  name = Carl Smedstad
  signingkey = 688CE83B917CD0CEF52AA14A49C93367BA86290E
[commit]
  gpgsign = true
[tag]
  gpgsign = true
[credential]
  helper = cache --timeout 3600
[color]
  ui = always
[merge]
  conflictstyle = diff3
[diff]
  colorMoved = default
  tool = nvimdiff
[difftool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[pull]
  ff = only
[push]
  autoSetupRemote = true
[submodule]
  recurse = false
[rebase]
  autosquash = true
[init]
  defaultBranch = master
[alias]
  br = branch
  ci = commit
  co = checkout
  glog = log --graph --oneline --decorate
  pushf = push --force-with-lease
  st = status --short --branch
  root = rev-parse --show-toplevel
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[ghq]
  vcs = git
  root = ~/repos
[include]
  path = ~/.config/git/config_extra
[includeIf "gitdir:~/repos/aur.archlinux.org/"]
  path = ~/.config/git/config_archlinux
[includeIf "gitdir:~/repos/gitlab.archlinux.org/"]
  path = ~/.config/git/config_archlinux
